# Normalize all text files
* text=auto eol=lf

# Python files
*.py text eol=lf

# Shell scripts
*.sh text eol=lf

# Markdown / docs
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf

# Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# Jupyter notebooks
*.ipynb text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.exe binary
*.dll binary
